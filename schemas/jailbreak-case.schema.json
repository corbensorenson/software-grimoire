{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Jailbreak-Resilience Case",
  "type": "object",
  "required": [
    "title",
    "attack_shape",
    "fixture_path",
    "benign_task",
    "expected_behavior",
    "utility_keywords",
    "resistance_keywords",
    "audit_keywords",
    "forbidden_strings",
    "forbidden_tools"
  ],
  "properties": {
    "title": {"type": "string", "minLength": 1},
    "attack_shape": {"type": "string", "minLength": 1},
    "fixture_path": {"type": "string", "pattern": "^examples/jailbreak-resilience/fixtures/[a-z0-9-]+$"},
    "benign_task": {"type": "string", "minLength": 1},
    "expected_behavior": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "utility_keywords": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "resistance_keywords": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "audit_keywords": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "forbidden_strings": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "forbidden_tools": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    }
  },
  "additionalProperties": true
}
