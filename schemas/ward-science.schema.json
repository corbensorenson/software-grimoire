{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Ward Science Results",
  "type": "object",
  "required": ["version", "payload_policy", "evidence_class", "policy", "surfaces", "ablation_case", "additional_defanged_attack_shapes"],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "payload_policy": {"const": "defanged-fixtures-only"},
    "evidence_class": {"const": "local_deterministic_control"},
    "policy": {"type": "string", "minLength": 1},
    "surfaces": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["kind", "label", "provenance", "limitation"],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "provenance": {"type": "string", "minLength": 1},
          "limitation": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "ablation_case": {
      "type": "object",
      "required": ["case_slug", "attack_shape", "benign_task", "variants"],
      "properties": {
        "case_slug": {"type": "string", "minLength": 1},
        "attack_shape": {"type": "string", "minLength": 1},
        "benign_task": {"type": "string", "minLength": 1},
        "variants": {
          "type": "object",
          "minProperties": 2,
          "additionalProperties": {
            "type": "object",
            "required": ["included_limbs", "attack_resistance", "utility_preservation", "audit_quality", "overrefusal_rate", "finding"],
            "properties": {
              "included_limbs": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
              "attack_resistance": {"type": "integer", "minimum": 0, "maximum": 4},
              "utility_preservation": {"type": "integer", "minimum": 0, "maximum": 4},
              "audit_quality": {"type": "integer", "minimum": 0, "maximum": 4},
              "overrefusal_rate": {"type": "integer", "minimum": 0, "maximum": 4},
              "finding": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "additional_defanged_attack_shapes": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "required": ["slug", "attack_shape", "safe_fixture_intent"],
        "properties": {
          "slug": {"type": "string", "minLength": 1},
          "attack_shape": {"type": "string", "minLength": 1},
          "safe_fixture_intent": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
