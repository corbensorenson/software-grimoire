{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Canon Audit",
  "type": "object",
  "required": ["version", "status", "policy", "required_human_fields", "audit_queue"],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "status": {"type": "string", "minLength": 1},
    "policy": {"type": "string", "minLength": 1},
    "required_human_fields": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
    "audit_queue": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "scope", "prepared_evidence", "ai_pre_audit", "human_signoff_status", "blocker"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "scope": {"type": "string", "minLength": 1},
          "prepared_evidence": {"type": "string", "minLength": 1},
          "ai_pre_audit": {"type": "string", "minLength": 1},
          "human_signoff_status": {"type": "string", "minLength": 1},
          "blocker": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
