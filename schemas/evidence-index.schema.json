{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Evidence Index",
  "type": "object",
  "required": ["version", "generated_at", "policy", "summary", "artifacts"],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "generated_at": {"type": "string", "minLength": 1},
    "policy": {"type": "string", "minLength": 1},
    "summary": {"type": "object", "additionalProperties": true},
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "path", "exists", "evidence_class", "calibration_role", "claim_scope", "run_count"],
        "properties": {
          "id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "path": {"type": "string", "minLength": 1},
          "exists": {"type": "boolean"},
          "bytes": {"type": "integer", "minimum": 0},
          "evidence_class": {"type": "string", "minLength": 1},
          "calibration_role": {"type": "string", "minLength": 1},
          "claim_scope": {"type": "string", "minLength": 1},
          "generated_at": {"type": ["string", "null"]},
          "surfaces": {"type": "array", "items": {"type": "string"}},
          "run_count": {"type": "integer", "minimum": 0},
          "passed": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
