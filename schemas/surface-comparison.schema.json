{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Surface Comparison",
  "type": "object",
  "required": ["version", "policy", "surfaces", "field_spell_matrix"],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "policy": {"type": "string", "minLength": 1},
    "surfaces": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["kind", "label", "provenance"],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "provenance": {"type": "string", "minLength": 1},
          "limitation": {"type": "string", "minLength": 1},
          "execution": {"type": "string", "minLength": 1},
          "evidence_class": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "field_spell_matrix": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["title", "surfaces"],
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "surfaces": {
            "type": "object",
            "minProperties": 2,
            "additionalProperties": {
              "type": "object",
              "required": ["delta", "evidence", "limitation"],
              "properties": {
                "delta": {"type": "string", "minLength": 1},
                "reviewability_delta": {"type": "string", "minLength": 1},
                "evidence": {"type": "string", "minLength": 1},
                "limitation": {"type": "string", "minLength": 1},
                "run_count": {"type": "integer", "minimum": 0},
                "tiers": {"type": "array", "items": {"type": "string", "minLength": 1}},
                "cells": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "required": ["surface", "tier", "weak_runs", "repaired_runs"],
                    "properties": {
                      "surface": {"type": "string", "minLength": 1},
                      "tier": {"type": "string", "minLength": 1},
                      "weak_runs": {"type": "integer", "minimum": 0},
                      "repaired_runs": {"type": "integer", "minimum": 0},
                      "weak_reviewability_avg": {"type": ["number", "null"]},
                      "repaired_reviewability_avg": {"type": ["number", "null"]},
                      "reviewability_delta": {"type": ["number", "null"]},
                      "weak_outcome_avg": {"type": ["number", "null"]},
                      "repaired_outcome_avg": {"type": ["number", "null"]},
                      "outcome_delta": {"type": ["number", "null"]}
                    },
                    "additionalProperties": false
                  }
                }
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
