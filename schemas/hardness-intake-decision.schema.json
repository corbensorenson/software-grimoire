{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Bench v4 Hardness Intake Decision",
  "type": "object",
  "required": [
    "schema_version",
    "decision_id",
    "generated_at",
    "status",
    "policy",
    "import_path",
    "surface_id",
    "benchmark",
    "case_slug",
    "variant",
    "repetition",
    "provenance",
    "maintainer",
    "review_date",
    "decision",
    "evidence_checked",
    "publication",
    "acceptance_notes",
    "counts_as_cross_surface_hardness",
    "blocks_hardness_credit"
  ],
  "properties": {
    "schema_version": {"const": "4.0.0-hardness-intake-decision"},
    "decision_id": {"type": "string", "pattern": "^hardness-intake\\.[a-z0-9][a-z0-9.-]*\\.v[0-9]+$"},
    "generated_at": {"type": "string", "minLength": 1},
    "status": {"enum": ["pending-maintainer", "maintainer-reviewed"]},
    "policy": {"type": "string", "minLength": 1},
    "import_path": {"type": "string", "minLength": 1},
    "surface_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "benchmark": {"const": "hardness-v4-model-surface"},
    "case_slug": {"type": "string", "minLength": 1},
    "variant": {"enum": ["weak", "repaired"]},
    "repetition": {"type": "integer", "minimum": 1},
    "provenance": {"enum": ["project-owned", "reviewer-supplied", "external-user"]},
    "maintainer": {"type": "string"},
    "review_date": {"type": "string"},
    "decision": {"enum": ["pending", "accept", "revise", "defer", "reject"]},
    "evidence_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "path_or_url", "notes"],
        "properties": {
          "kind": {"enum": ["import_record", "normalized_validation", "issue", "pull_request", "artifact", "test", "other"]},
          "path_or_url": {"type": "string", "minLength": 1},
          "notes": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "publication": {
      "type": "object",
      "required": ["status", "url_or_path"],
      "properties": {
        "status": {"enum": ["not-published", "pending", "published"]},
        "url_or_path": {"type": "string"}
      },
      "additionalProperties": false
    },
    "acceptance_notes": {"type": "string", "minLength": 1},
    "counts_as_cross_surface_hardness": {"type": "boolean"},
    "blocks_hardness_credit": {"type": "boolean"}
  },
  "additionalProperties": false
}
