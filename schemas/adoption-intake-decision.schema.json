{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Adoption Intake Decision",
  "type": "object",
  "required": [
    "schema_version",
    "decision_id",
    "generated_at",
    "status",
    "policy",
    "report_path",
    "report_id",
    "provenance",
    "maintainer",
    "review_date",
    "decision",
    "evidence_checked",
    "publication",
    "acceptance_notes",
    "counts_as_external_adoption",
    "blocks_external_adoption_credit"
  ],
  "properties": {
    "schema_version": {"const": "4.0.0-adoption-intake-decision"},
    "decision_id": {"type": "string", "pattern": "^adoption-intake\\.[a-z0-9][a-z0-9.-]*\\.v[0-9]+$"},
    "generated_at": {"type": "string", "minLength": 1},
    "status": {"enum": ["pending-maintainer", "maintainer-reviewed"]},
    "policy": {"type": "string", "minLength": 1},
    "report_path": {"type": "string", "minLength": 1},
    "report_id": {"type": "string", "pattern": "^adoption\\.[a-z0-9][a-z0-9-]*\\.v[0-9]+$"},
    "provenance": {"enum": ["project-owned", "reviewer-supplied", "external-user"]},
    "maintainer": {"type": "string"},
    "review_date": {"type": "string"},
    "decision": {"enum": ["pending", "accept", "revise", "defer", "reject"]},
    "evidence_checked": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["kind", "path_or_url", "notes"],
        "properties": {
          "kind": {"enum": ["report", "issue", "pull_request", "test", "artifact", "other"]},
          "path_or_url": {"type": "string", "minLength": 1},
          "notes": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "publication": {
      "type": "object",
      "required": ["status", "url_or_path"],
      "properties": {
        "status": {"enum": ["not-published", "pending", "published"]},
        "url_or_path": {"type": "string"}
      },
      "additionalProperties": false
    },
    "acceptance_notes": {"type": "string", "minLength": 1},
    "counts_as_external_adoption": {"type": "boolean"},
    "blocks_external_adoption_credit": {"type": "boolean"}
  },
  "additionalProperties": false
}
