{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Generator Architecture",
  "type": "object",
  "required": ["version", "components", "source_of_truth_rules", "determinism_policy"],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["component", "owns", "current_module", "future_module"],
        "properties": {
          "component": {"type": "string", "minLength": 1},
          "owns": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "current_module": {"type": "string", "minLength": 1},
          "future_module": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "source_of_truth_rules": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["surface", "paths", "edit_policy"],
        "properties": {
          "surface": {"type": "string", "minLength": 1},
          "paths": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "edit_policy": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "determinism_policy": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "additionalProperties": false
}
