{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Lexicon Entry",
  "type": "object",
  "required": [
    "id",
    "sigil",
    "term",
    "raw_term",
    "sense",
    "house",
    "house_name",
    "anchor",
    "page",
    "summary",
    "force",
    "shadow",
    "status",
    "completion_status",
    "is_stub",
    "major",
    "pocket",
    "source",
    "force_source"
  ],
  "properties": {
    "id": {"type": "integer", "minimum": 1},
    "sigil": {"type": "string", "pattern": "^[0-9]{4}$"},
    "term": {"type": "string", "minLength": 1},
    "raw_term": {"type": "string", "minLength": 1},
    "sense": {"type": "string", "minLength": 1},
    "house": {"type": "string", "minLength": 1},
    "house_name": {"type": "string", "minLength": 1},
    "anchor": {"type": "string", "pattern": "^rune-[0-9]{4}$"},
    "page": {"type": "string", "pattern": "^reference/house-[a-z0-9-]+\\.qmd$"},
    "summary": {"type": "string", "minLength": 1},
    "force": {"type": "string", "minLength": 1},
    "shadow": {"type": "string", "minLength": 1},
    "status": {"type": "string", "minLength": 1},
    "completion_status": {"enum": ["authored", "stub", "needs_shadow", "needs_sense"]},
    "is_stub": {"type": "boolean"},
    "major": {"type": "boolean"},
    "pocket": {"type": "boolean"},
    "source": {"type": "string", "minLength": 1},
    "force_source": {"enum": ["major-canon", "pocket-canon", "master-lexicon"]},
    "major_cluster": {"type": ["string", "null"]},
    "expanded_gloss": {"type": ["string", "null"]},
    "pocket_gloss": {"type": ["string", "null"]}
  },
  "additionalProperties": true
}
