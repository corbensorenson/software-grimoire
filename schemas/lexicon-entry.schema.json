{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Lexicon Entry",
  "type": "object",
  "required": ["id", "sigil", "term", "raw_term", "house", "summary", "status", "source"],
  "properties": {
    "id": {"type": "integer", "minimum": 1},
    "sigil": {"type": "string", "pattern": "^[0-9]{4}$"},
    "term": {"type": "string"},
    "raw_term": {"type": "string"},
    "sense": {"type": ["string", "null"]},
    "house": {"type": "string"},
    "summary": {"type": "string"},
    "force": {"type": "string"},
    "shadow": {"type": ["string", "null"]},
    "status": {"type": "string"},
    "major": {"type": "boolean"},
    "pocket": {"type": "boolean"},
    "source": {"type": "string"}
  }
}

