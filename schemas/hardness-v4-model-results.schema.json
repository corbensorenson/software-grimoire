{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Bench v4 Model-Surface Hardness Results",
  "type": "object",
  "required": [
    "generated_at",
    "version",
    "policy",
    "surfaces",
    "cases",
    "run_count",
    "minimum_repetitions_per_surface_variant"
  ],
  "properties": {
    "generated_at": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "policy": {"type": "string", "minLength": 1},
    "run_count": {"type": "integer", "minimum": 1},
    "minimum_repetitions_per_surface_variant": {"type": "integer", "minimum": 1},
    "surfaces": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "kind",
          "label",
          "provenance",
          "execution",
          "tool_name",
          "tool_version",
          "model_name",
          "evidence_class",
          "limitation"
        ],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "provenance": {"type": "string", "minLength": 1},
          "execution": {"type": "string", "minLength": 1},
          "tool_name": {"type": "string", "minLength": 1},
          "tool_version": {"type": "string", "minLength": 1},
          "model_name": {"type": "string", "minLength": 1},
          "evidence_class": {"type": "string", "minLength": 1},
          "limitation": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "cases": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": [
          "title",
          "rung",
          "hardness_axis",
          "fixture_path",
          "ground_truth_path",
          "artifact",
          "artifact_files",
          "test_file",
          "runs",
          "summary"
        ],
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "rung": {"type": "string", "enum": ["ambiguity", "hidden-invariant", "misleading-context", "blast-radius", "agentic"]},
          "hardness_axis": {"type": "string", "minLength": 1},
          "fixture_path": {"type": "string", "minLength": 1},
          "ground_truth_path": {"type": "string", "minLength": 1},
          "artifact": {"type": "string", "minLength": 1},
          "artifact_files": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
          "test_file": {"type": "string", "minLength": 1},
          "runs": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": [
                "surface",
                "surface_id",
                "surface_kind",
                "surface_label",
                "tool_name",
                "tool_version",
                "model_name",
                "provenance",
                "evidence_class",
                "redaction_policy",
                "case_slug",
                "title",
                "rung",
                "hardness_axis",
                "variant",
                "repetition",
                "run_timestamp",
                "fixture_path",
                "ground_truth_path",
                "prompt_path",
                "transcript_path",
                "artifact_root",
                "artifact_paths",
                "execution_command",
                "execution_result",
                "extraction_result",
                "grader_version"
              ],
              "properties": {
                "surface": {"type": "string", "minLength": 1},
                "surface_id": {"type": "string", "minLength": 1},
                "surface_kind": {"type": "string", "minLength": 1},
                "surface_label": {"type": "string", "minLength": 1},
                "tool_name": {"type": "string", "minLength": 1},
                "tool_version": {"type": "string", "minLength": 1},
                "model_name": {"type": "string", "minLength": 1},
                "provenance": {"type": "string", "minLength": 1},
                "evidence_class": {"type": "string", "minLength": 1},
                "redaction_policy": {"type": "string", "minLength": 1},
                "case_slug": {"type": "string", "minLength": 1},
                "title": {"type": "string", "minLength": 1},
                "rung": {"type": "string", "minLength": 1},
                "hardness_axis": {"type": "string", "minLength": 1},
                "variant": {"type": "string", "enum": ["weak", "repaired"]},
                "repetition": {"type": "integer", "minimum": 1},
                "run_timestamp": {"type": "string", "minLength": 1},
                "fixture_path": {"type": "string", "minLength": 1},
                "ground_truth_path": {"type": "string", "minLength": 1},
                "prompt_path": {"type": "string", "minLength": 1},
                "transcript_path": {"type": "string", "minLength": 1},
                "artifact_root": {"type": "string", "minLength": 1},
                "artifact_paths": {"type": "array", "items": {"type": "string"}},
                "execution_command": {"type": "string", "minLength": 1},
                "execution_result": {
                  "type": "object",
                  "required": ["status", "passed", "exit_code", "stdout", "stderr", "timeout_seconds"],
                  "properties": {
                    "status": {"type": "string", "enum": ["passed", "failed"]},
                    "passed": {"type": "boolean"},
                    "exit_code": {"type": "integer"},
                    "stdout": {"type": "string"},
                    "stderr": {"type": "string"},
                    "timeout_seconds": {"type": "integer", "minimum": 1}
                  },
                  "additionalProperties": false
                },
                "extraction_result": {
                  "type": "object",
                  "required": ["complete", "expected_files", "extracted_files", "errors"],
                  "properties": {
                    "complete": {"type": "boolean"},
                    "expected_files": {"type": "array", "minItems": 1, "items": {"type": "string", "minLength": 1}},
                    "extracted_files": {"type": "array", "items": {"type": "string"}},
                    "errors": {"type": "array", "items": {"type": "string"}}
                  },
                  "additionalProperties": false
                },
                "grader_version": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          },
          "summary": {
            "type": "object",
            "required": [
              "weak_runs",
              "repaired_runs",
              "weak_passes",
              "repaired_passes",
              "extraction_failures",
              "execution_delta",
              "paired_signs"
            ],
            "properties": {
              "weak_runs": {"type": "integer", "minimum": 1},
              "repaired_runs": {"type": "integer", "minimum": 1},
              "weak_passes": {"type": "integer", "minimum": 0},
              "repaired_passes": {"type": "integer", "minimum": 0},
              "extraction_failures": {"type": "integer", "minimum": 0},
              "execution_delta": {"type": "string", "minLength": 1},
              "paired_signs": {
                "type": "object",
                "required": ["repaired_wins", "weak_wins", "ties"],
                "properties": {
                  "repaired_wins": {"type": "integer", "minimum": 0},
                  "weak_wins": {"type": "integer", "minimum": 0},
                  "ties": {"type": "integer", "minimum": 0}
                },
                "additionalProperties": false
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
