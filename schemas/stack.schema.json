{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Stack",
  "type": "object",
  "required": [
    "id",
    "title",
    "version",
    "status",
    "enter",
    "inputs",
    "frames",
    "on_fail",
    "exit",
    "why_it_works",
    "source",
    "human_title",
    "working_seal",
    "formal_sigil",
    "runes",
    "related_spells"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^stack\\.[a-z0-9-]+\\.v[0-9]+$"},
    "title": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "status": {"type": "string", "minLength": 1},
    "enter": {"type": "string", "minLength": 1},
    "inputs": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "frames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["step", "spell", "artifact", "advance_when"],
        "properties": {
          "step": {"type": "integer", "minimum": 1},
          "spell": {"type": "string", "minLength": 1},
          "artifact": {"type": "string", "minLength": 1},
          "advance_when": {"type": "string", "minLength": 1}
        }
      }
    },
    "loop": {
      "type": ["object", "null"],
      "properties": {
        "recursive": {"type": "boolean"},
        "until": {"type": "string"},
        "base_case": {"type": "string"}
      }
    },
    "on_fail": {"type": "string", "minLength": 1},
    "exit": {"type": "string", "minLength": 1},
    "why_it_works": {"type": "string", "minLength": 1},
    "source": {"type": "string", "minLength": 1},
    "human_title": {"type": "string", "minLength": 1},
    "working_seal": {"type": "string", "pattern": "^stack://[a-z0-9-]+/[A-F0-9]{10}$"},
    "formal_sigil": {
      "type": "object",
      "required": ["canonical_stream", "digest_algorithm", "digest"],
      "properties": {
        "canonical_stream": {"type": "string", "minLength": 1},
        "digest_algorithm": {"type": "string", "minLength": 1},
        "digest": {"type": "string", "pattern": "^[A-F0-9]{10}$"}
      }
    },
    "runes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "integer", "minimum": 1}
    },
    "related_spells": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "pattern": "^[a-z0-9-]+$"}
    }
  },
  "additionalProperties": true
}
