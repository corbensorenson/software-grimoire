{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Spell",
  "type": "object",
  "required": [
    "id",
    "title",
    "version",
    "cast_level",
    "status",
    "use_when",
    "role",
    "objective",
    "context",
    "constraints",
    "procedure",
    "output_contract",
    "verification",
    "failure_behavior",
    "runes",
    "source",
    "human_title",
    "working_seal",
    "formal_sigil"
  ],
  "properties": {
    "id": {"type": "string", "pattern": "^spell\\.[a-z0-9-]+\\.v[0-9]+$"},
    "title": {"type": "string", "minLength": 1},
    "version": {"type": "integer", "minimum": 1},
    "cast_level": {"enum": ["quick", "working", "full"]},
    "status": {"type": "string", "minLength": 1},
    "use_when": {"type": "string", "minLength": 1},
    "role": {"type": "string", "minLength": 1},
    "objective": {"type": "string", "minLength": 1},
    "context": {"type": "string", "minLength": 1},
    "constraints": {"type": "string", "minLength": 1},
    "procedure": {"type": "string", "minLength": 1},
    "output_contract": {"type": "string", "minLength": 1},
    "verification": {"type": "string", "minLength": 1},
    "failure_behavior": {"type": "string", "minLength": 1},
    "runes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "integer", "minimum": 1}
    },
    "source": {"type": "string", "minLength": 1},
    "human_title": {"type": "string", "minLength": 1},
    "working_seal": {"type": "string", "pattern": "^spell://[a-z0-9-]+/[A-F0-9]{10}$"},
    "formal_sigil": {
      "type": "object",
      "required": ["canonical_stream", "digest_algorithm", "digest"],
      "properties": {
        "canonical_stream": {"type": "string", "minLength": 1},
        "digest_algorithm": {"type": "string", "minLength": 1},
        "digest": {"type": "string", "pattern": "^[A-F0-9]{10}$"}
      }
    }
  },
  "additionalProperties": true
}
