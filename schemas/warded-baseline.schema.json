{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Warded Baseline Matrix",
  "type": "object",
  "required": ["version", "payload_policy", "surfaces", "cases", "baseline_failures"],
  "properties": {
    "version": {"type": "string", "minLength": 1},
    "payload_policy": {"const": "defanged-fixtures-only"},
    "surfaces": {
      "type": "object",
      "minProperties": 2,
      "additionalProperties": {
        "type": "object",
        "required": ["kind", "label", "provenance"],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "provenance": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "cases": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["title", "fixture_path", "attack_shape", "runs"],
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "fixture_path": {"type": "string", "minLength": 1},
          "attack_shape": {"type": "string", "minLength": 1},
          "runs": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["surface", "variant", "repetition", "run_timestamp", "fixture_path", "prompt_path", "transcript_path", "output", "axis_totals", "total_score", "baseline_failure", "evaluator_notes"],
              "properties": {
                "surface": {"type": "string", "minLength": 1},
                "variant": {"enum": ["baseline", "warded"]},
                "repetition": {"type": "integer", "minimum": 1},
                "run_timestamp": {"type": "string", "minLength": 1},
                "fixture_path": {"type": "string", "minLength": 1},
                "prompt_path": {"type": "string", "minLength": 1},
                "transcript_path": {"type": "string", "minLength": 1},
                "output": {"type": "string", "minLength": 1},
                "axis_totals": {
                  "type": "object",
                  "required": ["attack_resistance", "utility_preservation", "audit_quality"],
                  "properties": {
                    "attack_resistance": {"type": "integer", "minimum": 0},
                    "utility_preservation": {"type": "integer", "minimum": 0},
                    "audit_quality": {"type": "integer", "minimum": 0}
                  },
                  "additionalProperties": false
                },
                "total_score": {"type": "integer", "minimum": 0},
                "baseline_failure": {"type": "boolean"},
                "evaluator_notes": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          }
        },
        "additionalProperties": false
      }
    },
    "baseline_failures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["case", "variant", "surface"],
        "properties": {
          "case": {"type": "string", "minLength": 1},
          "variant": {"type": "string", "minLength": 1},
          "surface": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
