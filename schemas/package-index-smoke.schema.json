{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Package-Index Smoke Check",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "status",
    "policy",
    "index",
    "index_url",
    "extra_index_url",
    "package",
    "version",
    "human_upload",
    "steps",
    "passed"
  ],
  "properties": {
    "schema_version": {"const": "4.0.0-package-index-smoke"},
    "generated_at": {"type": "string", "minLength": 1},
    "status": {"enum": ["pending_upload", "dry_run", "passed", "failed"]},
    "policy": {"type": "string", "minLength": 20},
    "index": {"enum": ["pypi", "testpypi"]},
    "index_url": {"type": "string", "minLength": 1},
    "extra_index_url": {"type": "string"},
    "package": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "human_upload": {
      "type": "object",
      "required": ["required", "uploader", "uploaded_at", "package_url"],
      "properties": {
        "required": {"type": "boolean"},
        "uploader": {"type": "string"},
        "uploaded_at": {"type": "string"},
        "package_url": {"type": "string"}
      },
      "additionalProperties": false
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "passed", "stdout", "stderr"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "stdout": {"type": "string"},
          "stderr": {"type": "string"},
          "remediation": {"type": "string"},
          "command": {"type": "string"}
        },
        "additionalProperties": false
      }
    },
    "passed": {"type": "boolean"}
  },
  "additionalProperties": false
}
