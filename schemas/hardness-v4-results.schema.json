{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Bench v4 Hardness Results",
  "type": "object",
  "required": ["generated_at", "version", "policy", "repetitions_per_variant", "surfaces", "cases"],
  "properties": {
    "generated_at": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "policy": {"type": "string", "minLength": 1},
    "repetitions_per_variant": {"type": "integer", "minimum": 1},
    "surfaces": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["kind", "label", "provenance", "limitation"],
        "properties": {
          "kind": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "provenance": {"type": "string", "minLength": 1},
          "limitation": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "cases": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object",
        "required": ["title", "rung", "hardness_axis", "fixture_path", "ground_truth_path", "artifact", "test_file", "runs", "summary"],
        "properties": {
          "title": {"type": "string", "minLength": 1},
          "rung": {"type": "string", "enum": ["ambiguity", "hidden-invariant", "misleading-context", "blast-radius", "agentic"]},
          "hardness_axis": {"type": "string", "minLength": 1},
          "fixture_path": {"type": "string", "minLength": 1},
          "ground_truth_path": {"type": "string", "minLength": 1},
          "artifact": {"type": "string", "minLength": 1},
          "test_file": {"type": "string", "minLength": 1},
          "runs": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "object",
              "required": ["case_slug", "title", "rung", "hardness_axis", "variant", "repetition", "surface", "fixture_path", "ground_truth_path", "artifact_path", "execution_command", "execution_result", "grader_version"],
              "properties": {
                "case_slug": {"type": "string", "minLength": 1},
                "title": {"type": "string", "minLength": 1},
                "rung": {"type": "string", "minLength": 1},
                "hardness_axis": {"type": "string", "minLength": 1},
                "variant": {"type": "string", "enum": ["weak", "repaired"]},
                "repetition": {"type": "integer", "minimum": 1},
                "surface": {"type": "string", "minLength": 1},
                "fixture_path": {"type": "string", "minLength": 1},
                "ground_truth_path": {"type": "string", "minLength": 1},
                "artifact_path": {"type": "string", "minLength": 1},
                "execution_command": {"type": "string", "minLength": 1},
                "execution_result": {
                  "type": "object",
                  "required": ["status", "passed", "exit_code", "stdout", "stderr", "timeout_seconds"],
                  "properties": {
                    "status": {"type": "string", "enum": ["passed", "failed"]},
                    "passed": {"type": "boolean"},
                    "exit_code": {"type": "integer"},
                    "stdout": {"type": "string"},
                    "stderr": {"type": "string"},
                    "timeout_seconds": {"type": "integer", "minimum": 1}
                  },
                  "additionalProperties": false
                },
                "grader_version": {"type": "string", "minLength": 1}
              },
              "additionalProperties": false
            }
          },
          "summary": {
            "type": "object",
            "required": ["weak_runs", "repaired_runs", "weak_passes", "repaired_passes", "execution_delta"],
            "properties": {
              "weak_runs": {"type": "integer", "minimum": 1},
              "repaired_runs": {"type": "integer", "minimum": 1},
              "weak_passes": {"type": "integer", "minimum": 0},
              "repaired_passes": {"type": "integer", "minimum": 0},
              "execution_delta": {"type": "string", "minLength": 1}
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
