{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Software Grimoire Bench v4 Manual Hardness Import",
  "type": "object",
  "required": [
    "schema_version",
    "surface_id",
    "surface_label",
    "surface_kind",
    "tool_name",
    "tool_version",
    "model_name",
    "provenance",
    "evidence_class",
    "redaction_policy",
    "redaction_statement",
    "reviewer_id",
    "reviewer_date",
    "benchmark",
    "case_slug",
    "variant",
    "repetition",
    "run_timestamp",
    "fixture_path",
    "prompt_path",
    "transcript_path",
    "artifact_root",
    "artifact_files",
    "execution_command",
    "safety_statement",
    "maintainer_decision",
    "evaluator_notes"
  ],
  "properties": {
    "schema_version": {"const": "4.0.0-hardness-manual-import"},
    "surface_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9._-]*$"},
    "surface_label": {"type": "string", "minLength": 1},
    "surface_kind": {"type": "string", "minLength": 1},
    "tool_name": {"type": "string", "minLength": 1},
    "tool_version": {"type": "string", "minLength": 1},
    "model_name": {"type": "string", "minLength": 1},
    "provenance": {"enum": ["project-owned", "reviewer-supplied", "external-user"]},
    "evidence_class": {
      "enum": [
        "project_owned_model_run",
        "reviewer_supplied_model_run",
        "external_user_model_run"
      ]
    },
    "redaction_policy": {"type": "string", "minLength": 1},
    "redaction_statement": {"type": "string", "minLength": 1},
    "reviewer_id": {"type": "string", "minLength": 1},
    "reviewer_date": {"type": "string", "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"},
    "benchmark": {"const": "hardness-v4-model-surface"},
    "case_slug": {"type": "string", "minLength": 1},
    "variant": {"enum": ["weak", "repaired"]},
    "repetition": {"type": "integer", "minimum": 1},
    "run_timestamp": {"type": "string", "minLength": 1},
    "fixture_path": {"type": "string", "minLength": 1},
    "prompt_path": {"type": "string", "minLength": 1},
    "transcript_path": {"type": "string", "minLength": 1},
    "artifact_root": {"type": "string", "minLength": 1},
    "artifact_files": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "execution_command": {"type": "string", "minLength": 1},
    "safety_statement": {"type": "string", "minLength": 1},
    "maintainer_decision": {"enum": ["pending", "accepted", "rejected"]},
    "evaluator_notes": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}
