{
  "version": "1.9.0-generator-architecture",
  "components": [
    {
      "component": "sources",
      "owns": [
        "source_extracts",
        "source lineage"
      ],
      "current_module": "grimoire_build.sources; scripts/bootstrap_project.py orchestrates",
      "future_module": "grimoire_build.sources"
    },
    {
      "component": "lexicon",
      "owns": [
        "houses",
        "major canon",
        "pocket canon",
        "master lexicon",
        "canon quality"
      ],
      "current_module": "grimoire_build.lexicon; scripts/bootstrap_project.py builds records",
      "future_module": "grimoire_build.lexicon"
    },
    {
      "component": "spells",
      "owns": [
        "spell records",
        "spell pages",
        "warded spell fields"
      ],
      "current_module": "grimoire_build.spells; scripts/bootstrap_project.py builds records and pages",
      "future_module": "grimoire_build.spells"
    },
    {
      "component": "stacks",
      "owns": [
        "stack records",
        "stack pages",
        "stack diagrams"
      ],
      "current_module": "grimoire_build.stacks; scripts/bootstrap_project.py builds records and pages",
      "future_module": "grimoire_build.stacks"
    },
    {
      "component": "bench",
      "owns": [
        "evaluation pages",
        "bench contracts",
        "adversarial harness pages"
      ],
      "current_module": "grimoire_build.bench; scripts/bootstrap_project.py writes pages",
      "future_module": "grimoire_build.bench"
    },
    {
      "component": "exports",
      "owns": [
        "prompt assets",
        "tool exports",
        "library bundles",
        "checksums"
      ],
      "current_module": "grimoire_build.exports; scripts/bootstrap_project.py writes assets",
      "future_module": "grimoire_build.exports"
    },
    {
      "component": "site",
      "owns": [
        "Quarto config",
        "reference pages",
        "navigation"
      ],
      "current_module": "grimoire_build.site; scripts/bootstrap_project.py writes pages",
      "future_module": "grimoire_build.site"
    },
    {
      "component": "seals",
      "owns": [
        "canonical streams",
        "working seals",
        "seal stability"
      ],
      "current_module": "grimoire_build.seals; scripts/bootstrap_project.py computes streams",
      "future_module": "grimoire_build.seals"
    }
  ],
  "source_of_truth_rules": [
    {
      "surface": "source manuscripts",
      "paths": [
        "source_docs/",
        "source_extracts/"
      ],
      "edit_policy": "Preserve as lineage; regenerate extracts from source documents when needed."
    },
    {
      "surface": "canonical data",
      "paths": [
        "data/*.json"
      ],
      "edit_policy": "Generated by bootstrap unless a future module explicitly owns the source record."
    },
    {
      "surface": "generated pages",
      "paths": [
        "chapters/",
        "reference/",
        "spells/",
        "stacks/",
        "examples/*/*.qmd"
      ],
      "edit_policy": "Edit generator or source data, then regenerate."
    },
    {
      "surface": "bench evidence",
      "paths": [
        "examples/evaluations/runs/",
        "examples/jailbreak-resilience/runs/"
      ],
      "edit_policy": "Preserve prompts, transcripts, surface labels, fixture paths, timestamps, scores, and notes."
    },
    {
      "surface": "release artifacts",
      "paths": [
        "prompts/",
        "exports/"
      ],
      "edit_policy": "Generated from canonical spell/stack data; verify with manifest checksums."
    }
  ],
  "determinism_policy": [
    "Bootstrap generation must be deterministic for committed generated artifacts.",
    "Working seals change only when canonical streams change.",
    "Release bundles use fixed archive metadata and manifest checksums."
  ]
}
